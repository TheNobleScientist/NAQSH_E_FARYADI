rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // contentBlocks collection (Public Read, Admin Write)
    match /contentBlocks/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email.lower() == "muhammadzainb@gmail.com";
    }
    
    // siteSettings collection (Public Read, Admin Write)
    match /siteSettings/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email.lower() == "muhammadzainb@gmail.com";
    }
    
    // ceoTasks collection (Private: Admin Read & Write only)
    match /ceoTasks/{document} {
      allow read, write: if request.auth != null && request.auth.token.email.lower() == "muhammadzainb@gmail.com";
    }
    
    // Fallback: Disallow everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
